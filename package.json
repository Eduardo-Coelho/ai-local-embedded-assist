{
  "name": "ai-local-embedded-assist",
  "version": "0.5.0",
  "description": "Build a Electron app with react, typescript",
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "copy-assets": "cp python_server.py dist/ && cp -r models dist/",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win:fast": "npm run build && electron-builder --win --config.compression=store",
    "install-python-deps": "pip install -r requirements.txt"
  },
  "author": "eduardo-coelho",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/node-fetch": "^2.6.12",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^27.1.3",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-backend-cpu": "^4.15.0",
    "@tensorflow/tfjs-backend-webgl": "^4.15.0",
    "@xenova/transformers": "^2.15.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.ai-local-embedded-assist.app",
    "productName": "AI Local Embedded Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "models/**/*",
      "python_server.py"
    ],
    "extraResources": [
      {
        "from": "node_modules/@tensorflow/tfjs-backend-cpu/dist/",
        "to": "tfjs-backend-cpu/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@tensorflow/tfjs-backend-webgl/dist/",
        "to": "tfjs-backend-webgl/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@xenova/transformers/dist/",
        "to": "transformers/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "portable",
      "forceCodeSigning": false
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
